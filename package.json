{
  "name": "wach-blog-portfolio",
  "version": "2.0.1",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "licenseText": "PROPRIETARY",
  "description": "Proprietary blog and portfolio website - All rights reserved",
  "author": {
    "name": "Nur Wachid",
    "email": "wachid@outlook.com",
    "url": "https://wach.id"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/turahe/blog.git"
  },
  "homepage": "https://wach.id",
  "keywords": [
    "blog",
    "portfolio",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "proprietary"
  ],
  "engines": {
    "node": "22.x.x",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "next dev --turbopack",
    "dev": "next dev --turbopack",
    "build": "next build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir app --dir components --dir lib --dir layouts --dir scripts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "test:e2e:report": "playwright show-report",
    "prepare": "node -e \"if (process.env.CI || process.env.VERCEL) process.exit(0); try { require('husky').install() } catch(e) { process.exit(0) }\""
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@headlessui/react": "2.2.9",
    "@heroicons/react": "^2.2.0",
    "@next/bundle-analyzer": "16.0.8",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@turahe/react-rough-notation": "2.0.2",
    "@types/node": "^24.10.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "body-scroll-lock": "^4.0.0-beta.0",
    "contentlayer2": "0.5.8",
    "cross-env": "^10.1.0",
    "esbuild": "0.27.1",
    "framer-motion": "^12.23.25",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "image-size": "^2.0.2",
    "media-chrome": "^4.16.1",
    "motion": "^12.23.25",
    "next": "^16.0.8",
    "next-contentlayer2": "0.5.8",
    "next-themes": "^0.4.6",
    "pliny": "0.4.1",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-katex-notranslate": "^1.1.4",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.0",
    "remark-math": "^6.0.0",
    "supports-color": "^10.2.2",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "typewriter-effect": "^2.22.0",
    "unist-util-visit": "^5.0.0",
    "use-sound": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@svgr/webpack": "^8.1.0",
    "@swc/core": "^1.15.3",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/identity-obj-proxy": "^3",
    "@types/jest": "^30.0.0",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}
