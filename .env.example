# Database
DATABASE_URL="postgresql://blog:blogpassword@localhost:5432/blog"

# Analytics (Umami)
NEXT_UMAMI_ID=
NEXT_UMAMI_SRC=

# Comments (Giscus) — https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Newsletter (Mailchimp)
MAILCHIMP_API_KEY=
MAILCHIMP_API_SERVER=
MAILCHIMP_AUDIENCE_ID=

# Build tooling
ANALYZE=
BASE_PATH=

# Docker: path to host .npmrc (registry tokens, legacy-peer-deps, etc.)
# NPMRC_PATH=C:\Users\you\.npmrc

# Auth (session cookies use secure flags in production automatically)
AUTH_TRUST_HOST=true

# Object storage — set STORAGE_DRIVER to minio (default), r2, or mock (CI)

# MinIO (local / Docker)
STORAGE_DRIVER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=blog-media
MINIO_REGION=us-east-1

# Cloudflare R2 (S3-compatible)
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=blog-media
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# R2_REGION=auto
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Mock filesystem storage (CI / tests)
# STORAGE_DRIVER=mock
# MOCK_STORAGE_DIR=.mock-storage
# MOCK_STORAGE_PUBLIC_URL=https://storage.mock.test
# MOCK_STORAGE_BUCKET=blog-media
