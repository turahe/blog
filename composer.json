{
    "name": "turahe/blog",
    "type": "project",
    "description": "Blog boilerplate system.",
    "keywords": [
        "framework",
        "laravel",
        "blog",
        "boilerplate"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.4|^8.0",
        "ext-json": "*",
        "ext-pdo": "*",
        "fideloper/proxy": "^4.4",
        "fruitcake/laravel-cors": "^2.0",
        "laravel/framework": "^8.0",
        "laravel/passport": "^10.0",
        "laravel/socialite": "^v5.0",
        "laravel/ui": "^3.0",
        "spatie/laravel-activitylog": "^3.14",
        "spatie/laravel-analytics": "^3.10",
        "spatie/laravel-medialibrary": "^9.4",
        "spatie/laravel-permission": "^3.16",
        "spatie/laravel-tags": "^3.0",
        "spatie/laravel-sitemap": "^5.7",
        "turahe/laravel-installer": "dev-master",
        "turahe/laravel-likeable": "dev-master",
        "turahe/master-data": "dev-master"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.5",
        "barryvdh/laravel-ide-helper": "^2.9",
        "beyondcode/laravel-dump-server": "^1.4",
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.12",
        "friendsofphp/php-cs-fixer": "^2.16",
        "laravel/dusk": "^6.1",
        "laravel/sail": "^1.2",
        "laravel/telescope": "^4.4",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^5.0",
        "phpunit/phpunit": "^9.5",
        "symfony/yaml": "^5.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
